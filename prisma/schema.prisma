datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PaymentProcessor {
  STRIPE
  CCBILL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum ModerationReviewStatus {
  PENDING
  APPROVED
  REMOVED
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  username               String    @unique
  password               String
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?

  sfwPrice  Int     @default(5)
  nsfwPrice Int     @default(10)
  isNsfw    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator       Creator?
  posts         Post[]         @relation("UserPosts")
  postLikes     PostLike[]
  subscriptions Subscription[]
  webhookEvents WebhookEvent[]

  @@index([resetPasswordTokenHash])
}

model Creator {
  id                String   @id @default(cuid())
  userId            String   @unique
  handle            String   @unique
  displayName       String?
  bio               String?
  avatarUrl         String?
  bannerUrl         String?
  classification    String   @default("SFW")
  platformFeeBps    Int      @default(2000)
  priceCents        Int      @default(1000)
  currency          String   @default("USD")
  billingPeriodDays Int      @default(30)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          User             @relation(fields: [userId], references: [id])
  subscriptions Subscription[]
  messages      CreatorMessage[]
}

model Post {
  id         String   @id @default(cuid())
  title      String
  content    String?
  isNsfw     Boolean  @default(false)
  authorId   String
  createdAt  DateTime @default(now())
  isLocked   Boolean  @default(false)
  priceCents Int?
  updatedAt  DateTime @updatedAt

  author            User               @relation("UserPosts", fields: [authorId], references: [id])
  media             PostMedia[]
  likes             PostLike[]
  moderationReviews ModerationReview[]
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostMedia {
  id       String    @id @default(cuid())
  postId   String
  url      String
  type     MediaType
  order    Int       @default(0)
  blurUrl  String?
  publicId String?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, order])
  @@index([publicId])
}

model ModerationReview {
  id              String                 @id @default(cuid())
  postId          String?
  pendingKey      String?                @unique
  creatorUserId   String
  creatorHandle   String?
  postTitle       String?
  source          String
  reason          String
  status          ModerationReviewStatus @default(PENDING)
  mediaPublicIds  Json?
  createdAt       DateTime               @default(now())
  reviewedAt      DateTime?
  reviewedByEmail String?

  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([postId, status])
  @@index([creatorUserId, createdAt])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  creatorId        String
  processor        PaymentProcessor
  externalId       String
  status           SubscriptionStatus
  currentPeriodEnd DateTime?
  startedAt        DateTime           @default(now())
  endedAt          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  creator Creator @relation(fields: [creatorId], references: [id])

  @@unique([processor, externalId])
  @@unique([userId, creatorId, processor])
  @@index([creatorId, processor, status])
  @@index([userId, processor, status])
}

model WebhookEvent {
  id          String           @id @default(cuid())
  payload     Json?
  userId      String?
  error       String?
  eventId     String
  eventType   String
  processedAt DateTime?
  processor   PaymentProcessor
  rawBody     String?
  receivedAt  DateTime         @default(now())
  status      String           @default("RECEIVED")

  user User? @relation(fields: [userId], references: [id])

  @@unique([processor, eventId])
  @@index([processor, receivedAt])
}

model CreatorMessage {
  id        String   @id @default(cuid())
  creatorId String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
}
